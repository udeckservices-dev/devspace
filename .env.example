#  DevSpace â€” Environment Configuration
#  Copy this file to .env and fill in values.
# â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

# Flask
SECRET_KEY=change-this-to-a-random-secret
FLASK_ENV=production

# â”€â”€ VPS / Git settings â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Your VPS IP address or domain name
VPS_HOST=your-vps-ip-or-domain

# SSH user that owns the Git repos (usually 'git' or your Linux username)
SSH_USER=git

# Directory on VPS where bare repos are stored
GIT_REPOS_BASE=/opt/devspace/repos

# Internal URL of this DevSpace app (used by post-receive hook to trigger deploy)
INTERNAL_URL=http://127.0.0.1:5000

# Shared secret between post-receive hook and DevSpace webhook endpoint
DEPLOY_SECRET=change-this-to-a-random-secret-too

# â”€â”€ Database â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Set to 'true' to use SQLite (easy for single-server setups)
USE_SQLITE=true

# MySQL (only if USE_SQLITE=false)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=devspace
DB_USER=root
DB_PASSWORD=
